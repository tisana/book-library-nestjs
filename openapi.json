  "info": {
    "title": "Book Library API",
    "description": "Staff-facing API for book borrowing workflows",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "example": "ChangeMe12345"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "StaffRole": {
        "type": "string",
        "enum": [
          "staff",
          "admin"
        ]
      },
      "StaffUserStatus": {
        "type": "string",
        "enum": [
          "active",
          "suspended",
          "inactive"
        ]
      },
      "StaffUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "email": {
            "type": "string",
            "example": "staff@example.com"
          },
          "displayName": {
            "type": "string",
            "example": "Circulation Staff"
          },
          "roles": {
            "type": "array",
            "example": [
              "staff"
            ],
            "items": {
              "$ref": "#/components/schemas/StaffRole"
            }
          },
          "status": {
            "allOf": [
              {
                "$ref": "#/components/schemas/StaffUserStatus"
              }
            ]
          },
          "lastLoginAt": {
            "type": "string",
            "format": "date-time",

{
  "name": "book-library",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migrate:up": "ts-node -r tsconfig-paths/register migrations/migrate.ts up",
    "migrate:status": "ts-node -r tsconfig-paths/register migrations/migrate.ts status",
    "auth:key-rotation:preflight": "ts-node --transpile-only -r tsconfig-paths/register scripts/preflight-auth-audit-key-rotation.ts",
    "auth:identifier-repair": "ts-node --transpile-only -r tsconfig-paths/register scripts/resolve-auth-identifier-conflict.ts",
    "verify:auth-performance": "npm run build && rimraf dist-performance && tsc -p tsconfig.performance.json && node dist-performance/scripts/verify-auth-performance.js",
    "bootstrap:admin": "ts-node -r tsconfig-paths/register scripts/bootstrap-admin.ts",
    "seed:users": "ts-node -r tsconfig-paths/register scripts/seed-sample-users.ts",
    "seed:demo": "ts-node -r tsconfig-paths/register scripts/seed-demo-data.ts",
    "seed:demo:reset": "ts-node -r tsconfig-paths/register scripts/seed-demo-data.ts --reset",
    "frontend:install": "npm install --prefix frontend",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:lint": "npm run lint --prefix frontend",
    "frontend:test": "npm run test --prefix frontend",
    "frontend:test:e2e": "npm run test:e2e --prefix frontend",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "mongodb-memory-server": "^11.2.0",
    "mongoose": "^9.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "proxy-addr": "^2.0.7",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^3.0.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/proxy-addr": "^2.0.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "supertest": "^4.0.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/bookstore?replicaSet=rs0

JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=book-library-local
JWT_AUDIENCE=book-library-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_COOKIE_SECRET=replace-with-a-long-random-cookie-secret

# Generate a new unpadded base64url value that decodes to at least 32 bytes.
AUTH_AUDIT_CORRELATION_SECRET=cmVwbGFjZS10aGlzLXdpdGgtYS1yYW5kb20tMzItYnl0ZS1rZXk
AUTH_AUDIT_CORRELATION_KEY_VERSION=1
AUTH_AUDIT_CORRELATION_PREVIOUS_KEYS={}

AUTH_IDENTIFIER_LEASE_SECONDS=300
AUTH_IDENTIFIER_RECONCILIATION_INTERVAL_SECONDS=60
AUTH_IDENTIFIER_RECONCILIATION_BATCH_SIZE=100
AUTH_IDENTIFIER_OPERATION_RETENTION_DAYS=90
AUTH_IDENTIFIER_MAX_OPERATION_ASSIGNMENTS=20

AUTH_SIGNIN_IDENTIFIER_FAILURE_LIMIT=5
AUTH_SIGNIN_SOURCE_LIMIT=20
AUTH_SIGNIN_WINDOW_SECONDS=900
AUTH_REFRESH_THROTTLE_LIMIT=30
AUTH_REFRESH_THROTTLE_WINDOW_SECONDS=300

# Keep this empty unless the API runs behind explicitly trusted proxies.
AUTH_TRUSTED_PROXY_CIDRS=[]
AUTH_TRUSTED_BROWSER_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

FIRST_ADMIN_EMAIL=admin@example.test
FIRST_ADMIN_PASSWORD=replace-with-a-unique-admin-password
FIRST_ADMIN_DISPLAY_NAME=Library Administrator
